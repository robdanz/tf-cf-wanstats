# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored and never committed.

# Your Cloudflare Account ID.
# Find at: Workers & Pages → Overview → right sidebar.
cloudflare_account_id = "your-cloudflare-account-id"

# Cloudflare API token for Terraform deployment.
# Required permissions: Account > D1 > Edit, Account > Workers Scripts > Edit, Account > Account Settings > Read
# Create at: https://dash.cloudflare.com/profile/api-tokens
cloudflare_api_token = "your-terraform-api-token"

# Your Cloudflare Workers subdomain (the part before .workers.dev).
# Find at: Workers & Pages → Overview → 'Your subdomain' in the right sidebar.
workers_subdomain = "your-subdomain"

# Cloudflare API token for the worker to query WAN analytics at runtime.
# Required permissions: Account > Account Analytics > Read
# Create at: https://dash.cloudflare.com/profile/api-tokens
wan_api_token = "your-wan-analytics-api-token"

# Secret token for authenticating POST /api/backfill requests.
# Generate with: openssl rand -hex 32
backfill_token = "your-backfill-token"
